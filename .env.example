# LLM Provider Configuration
# Supports any OpenAI-compatible API (OpenAI, DeepSeek, Kimi, Qwen, GLM, Ollama, etc.)

# Your API key
OPENAI_API_KEY=

# API base URL (optional — defaults to OpenAI)
# Examples:
#   OpenAI:    https://api.openai.com/v1
#   DeepSeek:  https://api.deepseek.com/v1
#   Ollama:    http://localhost:11434/v1
OPENAI_BASE_URL=

# Model name (optional — defaults to gpt-4o)
MODEL_NAME=
